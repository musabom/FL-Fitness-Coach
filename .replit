modules = ["nodejs-24", "postgresql-16"]

[[ports]]
localPort = 5173
externalPort = 80

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]

[deployment.postBuild.env]
CI = "true"

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.production]
ADMIN_SETUP_SECRET = "be2d2f9e78e3a88b2e8028724f9d8e1c5f9f342ee9579f11"
